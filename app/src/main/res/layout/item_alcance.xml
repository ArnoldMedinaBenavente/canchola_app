<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/mainContainerItem"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp"
    android:background="@android:color/white">

    <TextView
        android:id="@+id/tvNombreAlcance"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Nombre del concepto completo..."
        android:textColor="#1C1C1E"
        android:textSize="15sp"
        android:lineSpacingExtra="2dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/layoutRegistro"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@+id/tvNombreAlcance"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        <TextView
            android:id="@+id/tvIdConcept"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text=""
            android:visibility="gone"/>
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="AVANCE ACTUAL"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#8E8E93"
            android:letterSpacing="0.05" />

        <EditText
            android:id="@+id/etCantidadAvance"
            android:layout_width="90dp"
            android:layout_height="wrap_content"
            android:hint="0.00"
            android:inputType="numberDecimal"
            android:background="@drawable/bg_edittext_minimal"
            android:padding="10dp"
            android:textSize="15sp"
            android:textColor="#007AFF"
            android:textStyle="bold"
            android:textAlignment="center" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutRegistroActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end|center_vertical"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@+id/layoutRegistro"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAgregarFoto"
            style="@style/Widget.MaterialComponents.Button.TextButton.Icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Foto"
            app:icon="@android:drawable/ic_menu_camera"
            android:textColor="#007AFF"
            app:iconTint="#007AFF" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAgregarComentario"
            style="@style/Widget.MaterialComponents.Button.TextButton.Icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Comentar"
            app:icon="@android:drawable/ic_menu_edit"
            android:textColor="#007AFF"
            app:iconTint="#007AFF"
            android:layout_marginStart="8dp"/>
    </LinearLayout>

    <!-- Comentario con botón de voz -->
    <RelativeLayout
        android:id="@+id/layoutComentarioVoz"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@+id/layoutRegistroActions"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <EditText
            android:id="@+id/etComentario"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_toStartOf="@+id/btnVoiceAlcance"
            android:hint="Escribe un comentario..."
            android:inputType="textMultiLine"
            android:background="@drawable/bg_edittext_minimal"
            android:padding="10dp"
            android:textSize="14sp"
            android:textColor="#333333"
            android:textStyle="bold"
            android:textAlignment="center" />

        <ImageButton
            android:id="@+id/btnVoiceAlcance"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_btn_speak_now"
            app:tint="#007AFF" />
    </RelativeLayout>

    <LinearLayout
        android:id="@+id/layoutRegistroPhotos"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@+id/layoutComentarioVoz"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvPhotosHome"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="100dp"
            android:orientation="horizontal"
            android:padding="8dp"
            android:clipToPadding="false"
            android:visibility="visible"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />
    </LinearLayout>

    <View
        android:id="@+id/separator"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#F2F2F7"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/layoutRegistroPhotos"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>